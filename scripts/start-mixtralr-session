#!/usr/bin/env bash
# MixtralOS session launcher
# Chờ X server sẵn sàng trước khi launch PyQt6

export DISPLAY="${DISPLAY:-:0}"
export QT_QPA_PLATFORM=xcb
export XDG_CURRENT_DESKTOP=Mixtralr
export QT_SCALE_FACTOR=1
export QT_AUTO_SCREEN_SCALE_FACTOR=0

# XDG runtime dir
UID_VAL="$(id -u)"
export XDG_RUNTIME_DIR="/run/user/${UID_VAL}"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"

# Chờ X server sẵn sàng (tối đa 30 giây)
for i in $(seq 1 30); do
    if xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
        break
    fi
    sleep 1
done

# Fallback: nếu xcb thất bại thì thử offscreen
xdpyinfo -display "$DISPLAY" >/dev/null 2>&1 || export QT_QPA_PLATFORM=offscreen

# Set root window màu nền (tránh flash trắng)
xsetroot -solid '#080b14' 2>/dev/null || true


# Launch desktop with dbus (nm-applet started inside dbus session)
exec dbus-launch --exit-with-session \
    bash -c 'nm-applet 2>/dev/null & exec python3 /usr/share/mixtralr/desktop/splash.py'
